# ── Required ──────────────────────────────────────────────────────────────────
# Groq powers both Whisper transcription and LLaMA summarization.
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# MongoDB connection string for persistent storage.
# If left blank or unreachable, summaries save to backend/summaries.json instead.
# Free cluster: https://www.mongodb.com/atlas
MONGODB_URI=

# Port for the backend server (defaults to 3001).
PORT=3001
